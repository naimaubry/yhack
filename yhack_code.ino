void pickSauce() {
  static bool yesSelected = true;
  switch (currentScene) {
    case WELCOME:
      if (enterPressed()) {
        delay(200);
        currentScene = SOY_LEVEL;
        displaySceneBitmap(currentScene);
        printSerLCD("Soy level?", String(soyLevel) + "%");
      }
      break;

    // =======================
    case SOY_LEVEL:

      // Update potentiometer
      static int lastSoy = -1;
      soyLevel = readPotPercent();
      if (soyLevel != lastSoy) {
        Serial.print("Soy level updated: ");
        Serial.println(soyLevel);
        printSerLCD("Soy level?", String(soyLevel) + "%");
        lastSoy = soyLevel;
      }

      if (leftPressed()) {
        Serial.println("LEFT pressed");
        soyLevel = max(0, soyLevel - 1);
        delay(150);
      }

      if (rightPressed()) {
        Serial.println("RIGHT pressed");
        soyLevel = min(100, soyLevel + 1);
        delay(150);
      }

      if (enterPressed()) {
        Serial.println("ENTER pressed");
        delay(200);
        currentScene = SESAME_LEVEL;
        displaySceneBitmap(currentScene);
        printSerLCD("Sesame oil?", String(sesameLevel) + "%");
      }
      break;

    // =======================
    case SESAME_LEVEL:

      // Update potentiometer
      static int lastSesame = -1;
      sesameLevel = readPotPercent();
      if (sesameLevel != lastSesame) {
        Serial.print("Sesame level updated: ");
        Serial.println(sesameLevel);
        printSerLCD("Sesame level?", String(sesameLevel) + "%");
        lastSesame = sesameLevel;
      }

      if (leftPressed()) {
        Serial.println("LEFT pressed");
        sesameLevel = max(0, sesameLevel - 1);
        delay(150);
      }

      if (rightPressed()) {
        Serial.println("RIGHT pressed");
        sesameLevel = min(100, sesameLevel + 1);
        delay(150);
      }

      if (enterPressed()) {
        Serial.println("ENTER pressed");
        delay(200);
        currentScene = START_CONFIRM;
        displaySceneBitmap(currentScene);
        printSerLCD("Start?", "YES / NO");
      }
      break;

    // =======================
    case START_CONFIRM:
      if (leftPressed() || rightPressed()) {
        yesSelected = !yesSelected;
        printSerLCD("Start?", yesSelected ? "YES" : "NO");
        delay(200);
      }

      if (enterPressed()) {
        delay(200);
        if (yesSelected) {
          currentScene = MAKING_TOFU;
          displaySceneBitmap(currentScene);
          printSerLCD("Making Tofu...", "");
        } else {
          currentScene = WELCOME;
          displaySceneBitmap(currentScene);
          printSerLCD("WELCOME", "\nClick ENTER");
        }
      }
      break;

    // =======================
    case MAKING_TOFU:

      break;
  }
}

void automateProcess() {
  switch (currentStep) {
    case STEP_COMPRESS_HALF:
      printSerLCD("Compressing halfway...");

      // move actuator halfway code
      moveLeadScrew(LEADSCREW_PRESS_STEPS);
      stepStartTime = millis();
      currentStep = STEP_WAIT_20_MIN;
      break;

    case STEP_WAIT_20_MIN:
      printSerLCD("Waiting 20 min");
      if (millis() - stepStartTime > 20UL * 60UL * 1000UL) {
        currentStep = STEP_CUT_DOWN;
      }
      break;

    case STEP_CUT_DOWN:
      printSerLCD("Cutting");

      // insert code to move actuator full down
      moveLeadScrew(LEADSCREW_CUT_STEPS);
      delay(1000);

      currentStep = STEP_RETRACT_UP;
      break;

    case STEP_RETRACT_UP:
      printSerLCD("Retracting..");

      // insert code to move actuator up
      moveLeadScrew(0);
      delay(1000);

      currentStep = STEP_DISPENSE_SOY;
      break;

    case STEP_DISPENSE_SOY:
      printSerLCD("Soy", String(soyLevel) + "%");

      moveSoyServo(SOY_SERVO_OPEN);
      delay(map(soyLevel, 0, 100, 0, 1500));
      moveSoyServo(SOY_SERVO_CLOSED);
      currentStep = STEP_DISPENSE_SESAME;
      break;

    case STEP_DISPENSE_SESAME:
      printSerLCD("Sesame", String(sesameLevel) + "%");

      // open sesame valve
      moveSesameServo(SESAME_SERVO_OPEN);
      delay(map(sesameLevel, 0, 100, 0, 1500));
      // close sesame valve
      moveSesameServo(SESAME_SERVO_CLOSED);
      currentStep = STEP_PUSH_SYRINGE;
      break;

    case STEP_PUSH_SYRINGE:
      printSerLCD("Injecting sauce");

      // push syringe servo
      moveValve(VALVE_PUSH_STEPS);
      delay(500);
      moveValve(VALVE_RETRACT_STEPS);

      currentStep = STEP_DONE;
      break;

    case STEP_DONE:
      printSerLCD("Done!", "Enjoy");

      // servo to push tofu out of box
      activateBothEjectors();

      delay(3000);

      currentScene = WELCOME;
      currentStep = STEP_COMPRESS_HALF;
      break;
  }
}

